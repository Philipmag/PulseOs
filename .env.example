# ─────────────────────────────────────────────
# PulseOS environment template
# Copy to .env and fill in. NEVER commit the real .env (see Execution Rule #4).
# ─────────────────────────────────────────────

# --- AI Models ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_KEY=

# ModelRouter model identifiers (swappable without code changes)
MODEL_PRIMARY=claude-sonnet-4-6
MODEL_SECONDARY=gpt-4o
MODEL_EMBEDDING=text-embedding-3-large
# See NOTE in packages/database on embedding dimensions vs. pgvector index limits.
EMBEDDING_DIMENSIONS=1536

# --- Research & Intelligence ---
EXA_API_KEY=
FIRECRAWL_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_DATA_API_KEY=
NEWS_API_KEY=

# --- Publishing OAuth Apps ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# --- Infrastructure ---
DATABASE_URL=postgresql://pulseos:pulseos@localhost:5432/pulseos?schema=public
REDIS_URL=redis://localhost:6379
S3_BUCKET=pulseos-assets
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
TEMPORAL_ADDRESS=localhost:7233

# --- Auth & Billing ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Encryption (Execution Rule #4 / Security Requirements) ---
# 256-bit key, base64-encoded (generate: openssl rand -base64 32)
ENCRYPTION_KEY=
KMS_KEY_ID=

# --- Runtime ---
NODE_ENV=development
API_PORT=4000
# Boot mode for the shared NestJS codebase: "api" | "worker"
PROCESS_ROLE=api
